// Shopify SEO — local dev uses SQLite. For production on Railway,
// switch provider to "postgresql" and run `prisma migrate dev`.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Settings ----------

model Settings {
  id              Int      @id @default(1)
  shopDomain      String?  // e.g. mystore.myshopify.com
  shopifyToken    String?  // Admin API access token
  anthropicKey    String?
  judgeMeToken    String?  // Judge.me API token for pulling real reviews
  replicateToken  String?  // Replicate API token for ESRGAN upscaling
  optimizerRules  String?  // JSON: AI rules / brand voice / instructions
  redirect404ToHome Boolean @default(false) // 404 fallback: bounce to homepage
  robotsRules     String?  // JSON: custom robots.txt rules { ua, type, value }[]
  robotsBoostImages Boolean @default(false) // adds Allow rules for product images
  storeName       String?  // Human-readable store name for llms.txt header
  storeDescription String? // Store description blurb for llms.txt blockquote
  storefrontDomain String? // Public customer-facing domain (e.g. www.mystore.com). Falls back to shopDomain.
  indexNowKey     String?  // Random key hosted at /apps/.../feeds/indexnow-key.txt for IndexNow
  indexNowEnabled Boolean  @default(true) // If true, scanner pushes URLs to IndexNow on completion
  indexNowLastSubmittedAt   DateTime?
  indexNowLastSubmittedCount Int?
  indexNowLastError String?
  openaiKey       String?  // OpenAI API key (for LLM outreach)
  geminiKey       String?  // Google Gemini API key (for LLM outreach)
  perplexityKey   String?  // Perplexity API key (for LLM outreach)
  xaiKey          String?  // xAI / Grok API key (for LLM outreach)
  llmOutreachEnabled Boolean @default(true)
  llmOutreachProviders String? // JSON string[] of enabled providers: openai | anthropic | gemini | perplexity | xai
  llmOutreachWhatYouSell String?
  llmOutreachDifferentiator String?
  updatedAt       DateTime @updatedAt
}

// Log of every LLM outreach message sent. One row per provider per send.
model LLMOutreachMessage {
  id        String   @id @default(cuid())
  provider  String   // openai | anthropic | gemini | perplexity | xai
  status    String   // success | error
  message   String
  response  String?
  error     String?
  sentAt    DateTime @default(now())

  @@index([provider, sentAt])
  @@index([sentAt])
}

// Snapshot of original image bytes before any compress/rename operation,
// so we can revert later. Stores file content directly in Postgres.
model ImageBackup {
  id          String   @id @default(cuid())
  resourceId  String
  originalUrl String
  filename    String
  contentType String
  bytes       Bytes
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())

  @@index([resourceId])
  @@index([createdAt])
}

// ---------- Cached Shopify resources ----------

model Resource {
  id            String   @id // gid://shopify/Product/123 etc.
  type          String   // product | collection | page | article | blog
  handle        String?
  title         String?
  url           String?
  seoTitle      String?
  seoDescription String?
  bodyHtml      String?
  vendor        String?
  productType   String?
  tags          String?  // comma-separated
  status        String?
  raw           String?  // full JSON dump
  fetchedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  images        Image[]
  issues        Issue[]
  optimizations Optimization[]

  @@index([type])
}

model Image {
  id           String   @id // gid://shopify/ProductImage/...
  resourceId   String
  src          String
  altText      String?
  filename     String?
  width        Int?
  height       Int?
  bytes        Int?
  resource     Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

// ---------- Scans ----------

model ScanRun {
  id          String   @id @default(cuid())
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  status      String   @default("running") // running | done | failed
  totalPages  Int      @default(0)
  totalIssues Int      @default(0)
  log         String?  // newline log
  issues      Issue[]

  @@index([startedAt])
  @@index([status, startedAt])
}

model Issue {
  id         String   @id @default(cuid())
  scanId     String
  resourceId String?
  category   String   // meta_title | meta_description | alt_text | broken_link | 404 | json_ld | image_size | etc.
  severity   String   // info | warn | error
  message    String
  url        String?
  fixed      Boolean  @default(false)
  createdAt  DateTime @default(now())

  scan      ScanRun   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  resource  Resource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  @@index([scanId])
  @@index([category])
  @@index([resourceId])
}

// ---------- Optimizations (audit log of AI changes) ----------

model Optimization {
  id          String   @id @default(cuid())
  resourceId  String
  field       String   // seoTitle | seoDescription | altText | bodyHtml | tags
  oldValue    String?
  newValue    String?
  source      String   // ai | manual | rule
  model       String?  // claude model used
  createdAt   DateTime @default(now())

  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId])
}

// ---------- Tools ----------

model Redirect {
  id        String   @id @default(cuid())
  fromPath  String   @unique
  toPath    String
  createdAt DateTime @default(now())
}

model BrokenLink {
  id               String   @id @default(cuid())
  sourceUrl        String
  targetUrl        String
  status           Int
  foundAt          DateTime @default(now())
  kind             String   @default("link") // link | image
  sourceType       String?  // product | collection | article | page
  sourceResourceId String?
  sourceTitle      String?

  @@index([targetUrl])
  @@index([sourceType])
}

model SkipPage {
  // Either resourceId (skip a specific scanned resource) OR pattern (glob),
  // depending on how the user added it.
  id         String   @id @default(cuid())
  resourceId String?  @unique
  pattern    String?  @unique
  type       String   // product | collection | article | page (or "*" for pattern-based)
  createdAt  DateTime @default(now())
}

model NotFound {
  id        String   @id @default(cuid())
  url       String   @unique
  referrer  String?
  userAgent String?
  count     Int      @default(1)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  resolved  Boolean  @default(false)

  @@index([lastSeen])
  @@index([resolved])
  @@index([resolved, lastSeen])
}

model JobRun {
  id         String   @id @default(cuid())
  kind       String   // scan | optimize_all | compress_photos | etc.
  status     String   @default("queued") // queued | running | done | failed
  startedAt  DateTime?
  finishedAt DateTime?
  progress   Int      @default(0)
  total      Int      @default(0)
  error      String?
  createdAt  DateTime @default(now())

  @@index([status, finishedAt])
}
